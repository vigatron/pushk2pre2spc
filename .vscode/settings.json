{
	// Папка для сборки
	"cmake.buildDirectory": "${workspaceFolder}/build",
	// Генерация compile_commands.json для IntelliSense
	"cmake.exportCompileCommandsFile": true,
	// // Явный выбор компилятора (пример для GCC)
	// "cmake.configureSettings": {
	//     "CMAKE_C_COMPILER": "/usr/bin/gcc",
	//     "CMAKE_CXX_COMPILER": "/usr/bin/g++"
	// },
	"[cpp]": {
		"editor.defaultFormatter": "xaver.clang-format" // "ms-vscode.cpptools"
	},
	"[c]": {
		"editor.defaultFormatter": "xaver.clang-format"
	},
	"cmake.debugConfig": {
		"args": [
			// // 7E8BC0800080F0807A8BC288F2FBFBE400000000000000000000000000000000
			// "n",
			// "../examples/trix1.scr",
			// "6144"
			// ---
			"ints",
			"../examples/trix1.scr",
			"128", // "6144",
			"32", // "64"
		]
	},
	"python.testing.unittestEnabled": true,
	"python.testing.pytestEnabled": false,
	"python.testing.nosetestsEnabled": false,
	"python.testing.unittestArgs": [
		"-v",
		"-s",
		"./tests",
		"-p",
		"unittest1.py"
	],
	"python-envs.defaultEnvManager": "ms-python.python:system"
}